# ──────────────────────────────────────────────────────────────────────────────
# CPAG Graduate Research Monitoring System — Backend Environment Variables
# Copy this file to backend/.env and fill in all values before running Docker.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# Database (Docker Compose overrides this to use the mongodb service)
MONGO_URI=mongodb://mongodb:27017/cpagthesis

# JWT
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# Frontend URL (must match where users access the app in browser)
FRONTEND_URL=http://YOUR_SERVER_IP:3000
CORS_ORIGINS=http://YOUR_SERVER_IP:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://YOUR_SERVER_IP:5000/api/google-calendar/callback

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://YOUR_SERVER_IP:5000/api/google-calendar/callback

# Google Drive
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://YOUR_SERVER_IP:5000/api/google-drive/callback

# Google Drive Folder IDs
GOOGLE_DRIVE_CHAPTERS_FOLDER_ID=
GOOGLE_DRIVE_CHAPTER1_FOLDER_ID=
GOOGLE_DRIVE_CHAPTER2_FOLDER_ID=
GOOGLE_DRIVE_CHAPTER3_FOLDER_ID=
GOOGLE_DRIVE_COMPLIANCE_FOLDER_ID=
GOOGLE_DRIVE_PROGRAM_HEAD_FOLDER_ID=
GOOGLE_DRIVE_PROGRAM_HEAD_FORMS_FOLDER_ID=
GOOGLE_DRIVE_PROGRAM_HEAD_SCHEDULES_FOLDER_ID=
GOOGLE_DRIVE_PROGRAM_HEAD_PANEL_FOLDER_ID=
GOOGLE_DRIVE_DEAN_FOLDER_ID=
GOOGLE_DRIVE_DEAN_DOCUMENTS_FOLDER_ID=
GOOGLE_DRIVE_DEAN_REPORTS_FOLDER_ID=
GOOGLE_DRIVE_ADMIN_FOLDER_ID=

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Admin Account (seeded on first run)
ADMIN_EMAIL=admin@buksu.edu.ph
ADMIN_PASSWORD=CHANGE_ME

# Backup
ENABLE_AUTO_BACKUP=false
